# ============================================================
# ATENÇÃO: nunca versione este arquivo com valores reais.
# Copie para .env.local e preencha com suas credenciais.
# .env.local já está no .gitignore.
# ============================================================

# --- Autenticação do painel admin ---
# Gere com: openssl rand -base64 32
AUTH_SECRET=troque-por-uma-chave-aleatoria-forte

# Senha master do admin (fallback sem hash)
ADMIN_PASSWORD=troque-por-senha-forte

# Hash bcrypt/scrypt da senha (recomendado em produção)
# Gere com: npm run hash:admin -- sua-senha-forte
ADMIN_PASSWORD_HASH=

# Email do admin master (opcional — limita login ao email informado)
ADMIN_EMAIL=

# --- Supabase ---
NEXT_PUBLIC_SUPABASE_URL=https://SEU-PROJETO.supabase.co
SUPABASE_SERVICE_ROLE_KEY=SEU_SERVICE_ROLE_KEY
SUPABASE_STORAGE_BUCKET=product-images

# --- Shopee Affiliate API (opcional) ---
# Obtenha em: https://affiliate.shopee.com.br/portal
# ATENÇÃO: Revogue imediatamente se esta chave foi exposta em repositório Git.
SHOPEE_PARTNER_ID=
SHOPEE_SECRET_KEY=
